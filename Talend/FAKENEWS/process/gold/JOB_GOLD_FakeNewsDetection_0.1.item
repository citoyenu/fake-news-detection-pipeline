        <mapperTableEntries name="url" expression="row1.url " type="id_String" nullable="true"/>
        <mapperTableEntries name="fake_score" expression="((row1.word_count &lt; 100 ? 0.3 : 0.1) + (row1.title.toLowerCase().contains(&quot;shocking&quot;) || row1.title.toLowerCase().contains(&quot;breaking&quot;) ? 0.2 : 0.05)) / 2 " type="id_Double" nullable="true"/>
        <mapperTableEntries name="is_fake" expression="((row1.word_count &lt; 100 ? 0.3 : 0.1) + (row1.title.toLowerCase().contains(&quot;shocking&quot;) || row1.title.toLowerCase().contains(&quot;breaking&quot;) ? 0.2 : 0.05)) / 2 > 0.6 " type="id_Boolean" nullable="true"/>
        <mapperTableEntries name="confidence_level" expression="((row1.word_count &lt; 100 ? 0.3 : 0.1) + (row1.title.toLowerCase().contains(&quot;shocking&quot;) || row1.title.toLowerCase().contains(&quot;breaking&quot;) ? 0.2 : 0.05)) / 2 > 0.8 ? &quot;HIGH&quot; : (((row1.word_count &lt; 100 ? 0.3 : 0.1) + (row1.title.toLowerCase().contains(&quot;shocking&quot;) || row1.title.toLowerCase().contains(&quot;breaking&quot;) ? 0.2 : 0.05)) / 2 > 0.5 ? &quot;MEDIUM&quot; : &quot;LOW&quot;) " type="id_String" nullable="true"/>
        <mapperTableEntries name="detection_timestamp" expression="TalendDate.getDate(&quot;yyyy-MM-dd HH:mm:ss&quot;) " type="id_String" nullable="true"/>
